# EventPilot AI — Backend Environment Variables
# Copy this to .env and fill in your values

# --- App ---
DEBUG=true
CORS_ORIGINS=http://localhost:3000,https://eventpilot.vercel.app

# --- Supabase (REQUIRED) ---
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI: Google Gemini (REQUIRED for AI features) ---
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- AI: Hugging Face (Optional fallback) ---
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# --- AI: Ollama (Optional local fallback) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Email: Resend (Optional) ---
# Get from: https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=events@eventpilot.ai

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60
